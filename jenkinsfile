pipeline {
    agent any
    tools { nodejs 'nodejs'}

    stages {
        stage("Clonar o hub de leitura integrado") {
            steps {
                sh 'rm -rf hub-de-leitura-teste-ui || true'
                sh 'git clone https://github.com/priottomarcos7-coder/hub-de-leitura-teste-ui.git'
            }
        }

        stage("Instalar dependências do projeto") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    sh 'npm install'
                    sh 'nohup npm start &'
                }
            }
        }

        stage("Clonar o projeto de teste") {
            steps {
                sh 'rm -rf hub-de-leitura-teste-ui || true'
                sh 'git clone https://github.com/priottomarcos7-coder/hub-de-leitura-teste-ui.git'
            }
        }

        stage("Instalar dependências do projeto de teste") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    sh 'npm install'
                }
            }
        }

        stage("Executar os testes automatizados") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    sh 'npm test'
                }
            }
    }

    post {
         always {
            sh 'pkill -f "node" || true'
         }
    }

}

}