pipeline {
    agent any

    stages {
        stage('Instalar dependências') {
            steps {
                bat 'npm install'
            }
        }

        stage('Rodar Cypress') {
            steps {
                bat git clone https://github.com/priottomarcos7-coder/hub-de-leitura-teste-ui.git
                bat 'npx cypress run'
            }
        }
    }
}