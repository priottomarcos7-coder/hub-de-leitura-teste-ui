pipeline {
    agent any

    stages {
        stage('Instalar dependências') {
            steps {
                bat 'npm install'
            }
        }

        stage('Subir aplicação') {
            steps {
                bat 'start /B npm start'
            }
        }

        stage('Aguardar servidor') {
            steps {
                bat 'timeout /t 10'
            }
        }

        stage('Rodar Cypress') {
            steps {
                bat 'npx cypress run'
            }
        }
    }
}