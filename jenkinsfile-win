pipeline {
    agent any
    tools { nodejs 'nodejs'}

    stages {
        stage("Clonar o hub de leitura integrado") {
            steps {
                bat '''
                    if exist hub-de-leitura-teste-ui rmdir /s /q hub-de-leitura-teste-ui
                    git clone https://github.com/priottomarcos7-coder/hub-de-leitura-teste-ui.git
                '''
            }
        }

        stage("Instalar dependências do projeto") {
            steps { 
                dir('hub-de-leitura-teste-ui') {
                    bat '''
                        call npm install
                        start /B npm start
                    '''
                }
            }
        }

        stage("Clonar o projeto de teste") {
            steps {
                bat '''
                  if exist hub-de-leitura-teste-ui rmdir /s /q hub-de-leitura-teste-ui
                  git clone https://github.com/priottomarcos7-coder/hub-de-leitura-teste-ui.git  
                '''
            }
        }

        stage("Instalar dependências do projeto de teste") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    bat 'call npm install'
                }
            }
        }

        stage("Executar os testes automatizados") {
            steps {
                dir('hub-de-leitura-teste-ui') {
                    bat 'call npm test'
                }
            }
    }

    post { 
         always {
            bat 'taskkill /F /IM node.exe || exit 0'
         }
    }

}

}
